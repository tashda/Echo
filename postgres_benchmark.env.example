# Copy this file to `postgres_benchmark.env` and fill in your credentials.
# The run_postgres_streaming_bench.sh script will source it automatically.
ECHO_POSTGRES_HOST=HOST
ECHO_POSTGRES_PORT=5432
ECHO_POSTGRES_DATABASE=DB
ECHO_POSTGRES_USERNAME=USER
ECHO_POSTGRES_PASSWORD=PASSWORD
# Optional extras:
# ECHO_POSTGRES_SSL=false
# ECHO_POSTGRES_BASE_QUERY="SELECT * FROM schema.table"
