// Secrets.xcconfig.example — Copy this to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored and never committed.
//
// To get these values, set up your own self-hosted Supabase instance.
// See .planning/CLOUD_SYNC_PLAN.md for full setup instructions.

SLASH = /
SUPABASE_URL = https:$(SLASH)$(SLASH)your-supabase-instance.example.com
SUPABASE_ANON_KEY = your-supabase-anon-key-here
GOOGLE_CLIENT_ID = your-google-oauth-client-id.apps.googleusercontent.com
