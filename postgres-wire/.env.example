# Copy this file to .env and adjust values for local testing.

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DATABASE=postgres
# Set to true to require TLS, false to disable TLS
POSTGRES_TLS=false
# Optional application name
POSTGRES_APP_NAME=postgres-wire-tests

# Optional: enable long-running COPY benchmark in tests
# POSTGRES_BENCHMARK=1
